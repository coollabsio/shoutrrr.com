---
import Layout from '../layouts/Layout.astro';
import BrandIcon from '../components/marketing/BrandIcon.astro';
import Heart from 'lucide-astro/Heart';
import ArrowUpRight from 'lucide-astro/ArrowUpRight';
---

<Layout
  title="Sponsor us | Shoutrrr"
  description="Shoutrrr and coolLabs are self-funded and community-supported. Sponsor the project through GitHub Sponsors or Open Collective."
>
  <article class="mx-auto max-w-3xl px-6 pb-28 pt-16 md:pt-24">
    <header data-reveal class="max-w-2xl">
      <div
        class="mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
      >
        <Heart class="h-4 w-4" fill="currentColor" stroke-width={0} /> Open source
      </div>
      <h1
        class="font-display text-[clamp(36px,5vw,56px)] font-medium leading-[1.04]"
      >
        Sponsor us
      </h1>
      <p class="mt-6 text-[17px] leading-[1.7] text-ink-500">
        We're a self-funded company and depend on your support to sustain the
        project. That lets us focus on real users — like you — rather than on
        investors or revenue. If you run the self-hosted version, you can support
        our work through donations.
      </p>
    </header>

    <div data-reveal class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a
        href="https://github.com/sponsors/coollabsio"
        target="_blank"
        rel="noopener"
        data-hover
        class="flex w-full items-center justify-center gap-3 rounded-xl border border-line-strong bg-surface px-4 py-3.5 no-underline transition-colors hover:bg-surface-sunken sm:w-64"
      >
        <BrandIcon name="github" class="h-7 w-7 text-ink" />
        <span class="flex flex-col text-left">
          <span class="text-sm font-bold text-ink">GitHub Sponsors</span>
          <span class="text-xs text-ink-300">Donation</span>
        </span>
      </a>
      <a
        href="https://opencollective.com/coollabsio"
        target="_blank"
        rel="noopener"
        data-hover
        class="flex w-full items-center justify-center gap-3 rounded-xl border border-line-strong bg-surface px-4 py-3.5 no-underline transition-colors hover:bg-surface-sunken sm:w-64"
      >
        <svg class="h-7 w-7 text-net-bs" viewBox="0 0 24 24" fill="none">
          <path
            d="M16.6818 15.7529L18.8116 17.8827C20.1752 16.3052 21 14.249 21 12.0001C21 9.78747 20.2016 7.76133 18.8771 6.19409L16.7444 8.32671C17.5315 9.34177 18 10.6162 18 12.0001C18 13.4203 17.5066 14.7253 16.6818 15.7529Z"
            fill="currentColor"
            fill-opacity="0.5"></path>
          <path
            d="M15.6734 16.7445C14.6583 17.5315 13.3839 18 12 18C8.68629 18 6 15.3137 6 12C6 8.68629 8.68629 6 12 6C13.4202 6 14.7252 6.49344 15.7528 7.31823L17.8826 5.18843C16.3051 3.82482 14.2489 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21C14.2126 21 16.2387 20.2016 17.806 18.8771L15.6734 16.7445Z"
            fill="currentColor"></path>
        </svg>
        <span class="flex flex-col text-left">
          <span class="text-sm font-bold text-ink">Open Collective</span>
          <span class="text-xs text-ink-300">Donation</span>
        </span>
      </a>
    </div>

    <p data-reveal class="mt-8 text-[16px] leading-[1.7] text-ink-500">
      You can even get free visibility — 170k+ unique visitors per month across
      our landing pages, docs, and GitHub readmes — by buying a logo slot: a{' '}
      <a
        class="font-semibold text-ink underline decoration-lime-ring underline-offset-4 hover:text-lime-deep"
        href="https://github.com/sponsors/coollabsio/sponsorships?tier_id=61570&preview=false"
        >small</a
      >{' '}or a{' '}
      <a
        class="font-semibold text-ink underline decoration-lime-ring underline-offset-4 hover:text-lime-deep"
        href="https://github.com/sponsors/coollabsio/sponsorships?tier_id=334953&preview=false"
        >large</a
      >{' '}logo + link.
    </p>

    <!-- Who -->
    <section data-reveal class="mt-20 border-t border-line pt-12">
      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-medium">
        Who is behind this?
      </h2>
      <p class="mt-2 text-ink-400">
        A one-person mission that grew into a team.
      </p>
      <div class="mt-6 space-y-4 text-[16px] leading-[1.7] text-ink-500">
        <p>
          Hey, I'm{' '}
          <a
            href="https://twitter.com/heyandras"
            class="inline-flex items-center font-semibold text-ink underline decoration-lime-ring underline-offset-4 hover:text-lime-deep"
            >Andras Bacsai<ArrowUpRight class="ml-0.5 h-3.5 w-3.5" stroke-width={2.5} /></a
          >. I'm a software developer based in Hungary who became an independent
          entrepreneur in July 2022. I quit my job to focus entirely on my dream
          of devoting myself to open-source projects.
        </p>
        <p>
          Since the middle of 2024, I'm not the only one working on these
          projects. Thanks to sponsors and paid users, I've hired a developer
          and a few community support members who help me with the projects.
        </p>
        <p>
          If you find my open-source projects helpful or value my work, please
          consider{' '}
          <a
            href="https://github.com/sponsors/coollabsio"
            class="font-semibold text-ink underline decoration-lime-ring underline-offset-4 hover:text-lime-deep"
            >making a donation or sponsoring</a
          >. It guarantees the projects stay free, accessible, and keep
          developing — and lets me devote all my time to creating and enhancing
          them.
        </p>
        <p class="font-medium text-ink">Thank you!</p>
      </div>
    </section>
  </article>
</Layout>
