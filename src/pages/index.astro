---
import Layout from '../layouts/Layout.astro';
import Aura from '../components/marketing/Aura.astro';
import BrandIcon from '../components/marketing/BrandIcon.astro';
import ComposerMockup from '../components/marketing/ComposerMockup.svelte';
import Showcase from '../components/marketing/Showcase.svelte';
import PenLine from 'lucide-astro/PenLine';
import Send from 'lucide-astro/Send';
import CalendarDays from 'lucide-astro/CalendarDays';
import LineChart from 'lucide-astro/LineChart';
import Link2 from 'lucide-astro/Link2';
import Users from 'lucide-astro/Users';
import Bell from 'lucide-astro/Bell';
import ShieldCheck from 'lucide-astro/ShieldCheck';
import Zap from 'lucide-astro/Zap';
import Server from 'lucide-astro/Server';
import KeyRound from 'lucide-astro/KeyRound';
import CircleSlash from 'lucide-astro/CircleSlash';
import Check from 'lucide-astro/Check';
import Cloud from 'lucide-astro/Cloud';

const GITHUB = 'https://github.com/coollabsio/shoutrrr';
const CLOUD = 'https://app.shoutrrr.com';

const pillars = [
  {
    icon: Server,
    title: 'Self-host or Cloud',
    body: 'Run it on your own box with a single Docker image, or start in seconds on our managed Cloud — the same app, your choice.',
  },
  {
    icon: KeyRound,
    title: 'Your data, your rules',
    body: 'Self-host and your posts, tokens, and analytics live on infrastructure you control. Credentials are encrypted at rest and refreshed automatically.',
  },
  {
    icon: CircleSlash,
    title: 'No per-seat pricing',
    body: 'Invite the whole team into a workspace. The open-source app is free forever — no per-head, per-post, or per-month seat fees.',
  },
];

const features = [
  { icon: PenLine, title: 'Composer', body: 'Draft with media and alt text, watch a live character count per network, and auto-split long posts into threads where supported.' },
  { icon: Send, title: 'Multi-account publishing', body: 'Fan one post out to many accounts at once with optional per-platform overrides. Each target publishes independently and retries on failure.' },
  { icon: CalendarDays, title: 'Queue & calendar', body: 'Set recurring posting slots in your timezone, drop drafts into the queue, and review everything on a month calendar. Publish instantly anytime.' },
  { icon: LineChart, title: 'Analytics', body: 'Follower and post-count trends per account, plus per-post engagement: likes, reposts, replies, and impressions.' },
  { icon: Link2, title: 'Connected accounts', body: 'Link via OAuth (X, LinkedIn) or app password (Bluesky), group accounts into reusable sets, and get nudged when one needs reconnecting.' },
  { icon: Users, title: 'Workspaces & team', body: 'Multiple workspaces with role-based memberships, email invitations, and ownership transfer. Every record is scoped to its workspace.' },
  { icon: Bell, title: 'Notifications', body: 'In-app alerts the moment a post publishes or fails, or when an account needs your attention to keep posting.' },
  { icon: ShieldCheck, title: 'Secure by default', body: 'Email/password with verification, two-factor (TOTP), passkeys (WebAuthn), and optional social login.' },
  { icon: Zap, title: 'Fast & flexible', body: 'A single, snappy interface — self-host it on your own infrastructure, or run it on our managed Cloud. No lock-in either way.' },
];

const security = [
  { tag: '2FA', title: 'TOTP', body: 'Time-based one-time codes from any authenticator app.' },
  { tag: 'Passkeys', title: 'WebAuthn', body: 'Phishing-resistant passwordless sign-in with device biometrics.' },
  { tag: 'SSO', title: 'Social login', body: 'Optional Google, X, and LinkedIn sign-in for your team.' },
  { tag: 'At rest', title: 'Encrypted tokens', body: 'Credentials encrypted on disk and refreshed automatically.' },
];

const networks = [
  { name: 'X', icon: 'x' as const },
  { name: 'LinkedIn', icon: 'linkedin' as const },
  { name: 'Bluesky', icon: 'bluesky' as const },
];

const faqs = [
  {
    q: 'What platforms does Shoutrrr support?',
    a: 'X, Bluesky, and LinkedIn today. Write once, adjust each post when needed, and schedule everything from one place. More networks are on the roadmap.',
  },
  {
    q: 'Is Shoutrrr really free?',
    a: 'The open-source app is free forever under Apache 2.0 — self-host it with no paid seats or locked features. Managed Shoutrrr Cloud is $10/mo (which includes $5 of X usage) for teams who would rather not run it themselves.',
  },
  {
    q: 'Do I have to self-host?',
    a: 'No. Shoutrrr Cloud is live — sign up and start posting in seconds. Self-hosting stays free and open source if you would rather run it yourself.',
  },
  {
    q: 'How do I install it?',
    a: 'Self-hosting: pull the prebuilt Docker image — it bundles the web app, queue worker, and scheduler in one container and defaults to SQLite with no external services. Prefer zero setup? Skip it entirely with Shoutrrr Cloud.',
  },
  {
    q: 'Cloud or self-host — which should I pick?',
    a: 'Pick Cloud if you want zero ops — we run and update everything for a flat monthly fee. Pick self-host if you want full control of your infrastructure and data; it is free and open source. Same app either way — see the pricing section above for the details.',
  },
  {
    q: 'Can I use it with my team?',
    a: 'Yes. Invite teammates into shared workspaces with role-based access, and keep different brands, clients, or projects cleanly separated.',
  },
  {
    q: 'Is my data safe?',
    a: 'Shoutrrr is self-hosted, so your posts, accounts, and analytics stay on infrastructure you control. Account tokens are encrypted at rest.',
  },
  {
    q: 'How do I contribute?',
    a: 'Open an issue or pull request on GitHub — bug reports, docs, and features all help. The whole project is Apache 2.0 licensed.',
  },
];
---

<Layout>
  <!-- ===== HERO ===== -->
  <section
    class="mx-auto grid max-w-site items-center gap-10 overflow-hidden px-6 pb-10 pt-14 md:grid-cols-[1.05fr_1fr] md:gap-14 md:overflow-visible md:pt-[72px]"
  >
    <div class="min-w-0">
      <a
        href={CLOUD}
        data-reveal
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-line bg-surface-sunken px-3 py-1.5 text-[12.5px] font-medium text-ink-600 no-underline transition-colors hover:border-line-strong"
      >
        <Cloud class="h-4 w-4 text-lime-text" stroke-width={1.8} />
        Shoutrrr Cloud is live →
      </a>
      <h1
        data-reveal
        data-reveal-delay="0.06"
        class="font-display text-[clamp(42px,5.6vw,66px)] font-medium leading-[1.02]"
      >
        Draft once.<br />Post everywhere.<br /><span
          class="italic"
          style="color:oklch(0.5 0.13 130)">On your own terms.</span
        >
      </h1>
      <p
        data-reveal
        data-reveal-delay="0.12"
        class="mb-8 mt-[22px] max-w-[480px] text-[18px] leading-[1.6] text-ink-500"
      >
        Shoutrrr is the open-source alternative to Buffer, Typefully, and
        Hootsuite. Start on managed Shoutrrr Cloud, or self-host the open-source
        app — the same product, your choice. Write a post once and fan it out to
        X, Bluesky, and LinkedIn at the same time, or queue it on a recurring
        schedule.
      </p>
      <div
        data-reveal
        data-reveal-delay="0.18"
        class="mb-[26px] flex flex-col gap-3 min-[430px]:flex-row min-[430px]:flex-wrap"
      >
        <a
          href={CLOUD}
          data-hover
          data-hover-lift="-3"
          class="rounded-[11px] border border-lime-ring bg-lime px-[22px] py-[13px] text-center text-[15px] font-semibold text-lime-deep no-underline transition-[filter] hover:brightness-[1.04]"
          >Get started →</a
        >
        <a
          href="#pricing"
          data-hover
          data-hover-lift="-3"
          class="rounded-[11px] border border-line-strong bg-surface px-[22px] py-[13px] text-center text-[15px] font-semibold text-ink-700 no-underline transition-colors hover:bg-surface-sunken"
          >Self-host</a
        >
      </div>
      <div
        data-reveal
        data-reveal-delay="0.24"
        class="flex flex-wrap items-center gap-x-[18px] gap-y-2 text-[13px] text-ink-300"
      >
        <span class="flex items-center gap-1.5"
          ><Check class="h-4 w-4 text-lime-text" stroke-width={2.5} /> Set up in
          seconds</span
        >
        <span class="flex items-center gap-1.5"
          ><Check class="h-4 w-4 text-lime-text" stroke-width={2.5} /> Self-host
          anytime, no lock-in</span
        >
      </div>
    </div>

    <!-- Composer mockup + aura -->
    <div data-reveal data-reveal-delay="0.1" class="relative min-w-0 max-w-full">
      <Aura variant="hero" />
      <ComposerMockup client:load />
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="mx-auto max-w-site px-6 pb-16 pt-6">
    <div
      data-reveal
      class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3.5 rounded-2xl border border-line-soft bg-surface-sunken px-6 py-[22px]"
    >
      <span class="text-[13px] font-semibold text-ink-400"
        >Publishes independently to</span
      >
      {
        networks.map((n) => (
          <span class="flex items-center gap-2 text-sm font-semibold text-ink-700">
            <BrandIcon name={n.icon} brand class="h-[18px] w-[18px]" />
            {n.name}
          </span>
        ))
      }
      <span class="border-l border-line-strong pl-6 text-[13px] text-ink-300"
        >more networks coming soon</span
      >
    </div>
  </section>

  <!-- ===== VALUE PILLARS ===== -->
  <section id="selfhost" class="mx-auto max-w-site px-6 pb-24 pt-2">
    <div class="grid gap-5 md:grid-cols-3">
      {
        pillars.map((p, i) => {
          const Icon = p.icon;
          return (
            <div
              data-reveal
              data-reveal-delay={(i * 0.08).toFixed(2)}
              data-hover
              class="rounded-2xl border border-line-soft p-7"
            >
              <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-lime-soft text-lime-deep">
                <Icon class="h-[22px] w-[22px]" stroke-width={1.7} />
              </div>
              <h3 class="mb-2 font-display text-[21px] font-medium">{p.title}</h3>
              <p class="m-0 text-[14.5px] leading-[1.6] text-ink-500">{p.body}</p>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section id="pricing">
    <div class="mx-auto max-w-site px-6 py-24">
      <div data-reveal class="mx-auto mb-11 max-w-[620px] text-center">
        <div
          class="mb-3.5 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
        >
          Cloud or self-host
        </div>
        <h2
          class="font-display text-[clamp(30px,4vw,44px)] font-medium leading-[1.08]"
        >
          Two ways to run Shoutrrr
        </h2>
        <p class="mt-3.5 text-base leading-[1.6] text-ink-500">
          Same app, same features. Let us run it for you, or run it yourself —
          the open-source app is free forever.
        </p>
      </div>
      <div class="mx-auto grid max-w-[860px] gap-5 md:grid-cols-2">
        <!-- Cloud card (recommended) -->
        <div
          data-reveal
          data-hover
          class="relative flex flex-col rounded-2xl border border-lime-ring bg-surface p-8"
        >
          <div
            class="absolute right-5 top-5 rounded-full bg-lime-soft px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-lime-deep"
          >
            Recommended
          </div>
          <div class="mb-1 flex items-center gap-2 text-lime-deep">
            <Cloud class="h-5 w-5" stroke-width={1.8} />
            <span class="font-display text-[21px] font-medium">Shoutrrr Cloud</span>
          </div>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="font-display text-[40px] font-medium leading-none">$10</span>
            <span class="text-[15px] text-ink-400">/ month</span>
          </div>
          <p class="mt-1.5 text-[13.5px] text-ink-400">
            includes $5 of X (Twitter) API usage
          </p>
          <ul class="mt-6 flex flex-col gap-3 text-[14.5px] text-ink-600">
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-lime-text" stroke-width={2.5} />
              Fully managed and always up to date
            </li>
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-lime-text" stroke-width={2.5} />
              We run the infrastructure — no servers to babysit
            </li>
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-lime-text" stroke-width={2.5} />
              Set up in seconds, cancel anytime
            </li>
          </ul>
          <a
            href={CLOUD}
            data-hover
            data-hover-lift="-3"
            class="mt-8 rounded-[11px] border border-lime-ring bg-lime px-[22px] py-[13px] text-center text-[15px] font-semibold text-lime-deep no-underline transition-[filter] hover:brightness-[1.04]"
            >Get started →</a
          >
        </div>

        <!-- Self-host card -->
        <div
          data-reveal
          data-reveal-delay="0.08"
          data-hover
          class="flex flex-col rounded-2xl border border-line-soft bg-surface p-8"
        >
          <div class="mb-1 flex items-center gap-2 text-ink-700">
            <Server class="h-5 w-5" stroke-width={1.8} />
            <span class="font-display text-[21px] font-medium">Self-host</span>
          </div>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="font-display text-[40px] font-medium leading-none">Free</span>
            <span class="text-[15px] text-ink-400">forever</span>
          </div>
          <p class="mt-1.5 text-[13.5px] text-ink-400">
            Apache 2.0, open source
          </p>
          <ul class="mt-6 flex flex-col gap-3 text-[14.5px] text-ink-600">
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-ink-400" stroke-width={2.5} />
              Your infrastructure, your data
            </li>
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-ink-400" stroke-width={2.5} />
              No per-seat pricing, ever
            </li>
            <li class="flex items-start gap-2.5">
              <Check class="mt-0.5 h-[18px] w-[18px] flex-shrink-0 text-ink-400" stroke-width={2.5} />
              One Docker image — web, worker, scheduler
            </li>
          </ul>
          <a
            href={GITHUB}
            data-hover
            data-hover-lift="-3"
            class="mt-8 inline-flex items-center justify-center gap-2 rounded-[11px] border border-line-strong bg-surface px-[22px] py-[13px] text-center text-[15px] font-semibold text-ink-700 no-underline transition-colors hover:bg-surface-sunken"
            ><BrandIcon name="docker" class="h-[18px] w-[18px]" /> Deploy with Docker →</a
          >
        </div>
      </div>
      <p data-reveal class="mt-8 text-center text-[13.5px] text-ink-400">
        Same app, same features — your choice.
      </p>
    </div>
  </section>

  <!-- ===== INTERACTIVE SHOWCASE ===== -->
  <section id="showcase" class="border-y border-line-soft bg-surface-sunken">
    <div class="mx-auto max-w-site px-6 py-24">
      <div data-reveal class="mx-auto mb-11 max-w-[620px] text-center">
        <div
          class="mb-3.5 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
        >
          One fast interface
        </div>
        <h2
          class="font-display text-[clamp(30px,4vw,44px)] font-medium leading-[1.08]"
        >
          Everything from drafting to results
        </h2>
        <p class="mt-3.5 text-base leading-[1.6] text-ink-500">
          Compose, queue, and measure without ever leaving the app — or
          switching between five browser tabs.
        </p>
      </div>
      <div data-reveal data-reveal-delay="0.08">
        <Showcase client:visible />
      </div>
    </div>
  </section>

  <!-- ===== FEATURES GRID ===== -->
  <section id="features" class="mx-auto max-w-site px-6 py-24">
    <div data-reveal class="mb-11 max-w-[560px]">
      <div
        class="mb-3.5 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
      >
        The whole toolkit
      </div>
      <h2
        class="font-display text-[clamp(30px,4vw,44px)] font-medium leading-[1.08]"
      >
        Built for individuals and teams alike
      </h2>
    </div>
    <div
      data-reveal
      class="grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        features.map((f) => {
          const Icon = f.icon;
          return (
            <div class="bg-surface p-7 transition-colors hover:bg-surface-raised">
              <Icon class="mb-3.5 h-[22px] w-[22px] text-ink-700" stroke-width={1.7} />
              <h3 class="mb-2 text-base font-bold -tracking-[0.01em]">{f.title}</h3>
              <p class="m-0 text-sm leading-[1.6] text-ink-500">{f.body}</p>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- ===== SECURITY (dark) ===== -->
  <section id="security" class="bg-ink-900 text-white">
    <div
      class="mx-auto grid max-w-site items-center gap-14 px-6 py-24 md:grid-cols-2"
    >
      <div data-reveal>
        <div
          class="mb-4 text-xs font-semibold uppercase tracking-[0.14em]"
          style="color:oklch(0.83 0.18 128.85)"
        >
          Secure by default
        </div>
        <h2
          class="font-display text-[clamp(30px,4vw,46px)] font-medium leading-[1.06]"
        >
          Your accounts,<br />locked down tight
        </h2>
        <p class="mt-[18px] max-w-[440px] text-base leading-[1.65] text-white/70">
          Email and password with verification out of the box, plus every modern
          factor you'd want layered on top. Account tokens are encrypted at rest
          and never stored in plain text.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3.5">
        {
          security.map((s, i) => (
            <div
              data-reveal
              data-reveal-delay={(i * 0.06).toFixed(2)}
              class="rounded-[13px] border border-white/10 bg-white/[0.03] p-5"
            >
              <div
                class="mb-1.5 text-[13px] font-bold"
                style="color:oklch(0.83 0.18 128.85)"
              >
                {s.tag}
              </div>
              <div class="mb-1 text-sm font-semibold">{s.title}</div>
              <div class="text-[13px] leading-[1.5] text-white/60">{s.body}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section id="get" class="mx-auto max-w-site px-6 py-20 sm:py-[104px]">
    <div
      data-reveal
      class="relative overflow-hidden rounded-3xl border border-line-strong bg-surface-raised px-6 py-16 text-center sm:px-10 sm:py-[72px]"
    >
      <Aura variant="cta" />
      <div class="relative z-10">
        <h2
          class="font-display text-[clamp(32px,4.5vw,52px)] font-medium leading-[1.05]"
        >
          Own your posting workflow
        </h2>
        <p
          class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-[1.6] text-ink-500"
        >
          Get started on managed Cloud in seconds — or spin up your own
          instance, free and open source. Same app, your choice.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href={CLOUD}
            data-hover
            data-hover-lift="-3"
            class="inline-flex items-center gap-2 rounded-xl border border-lime-ring bg-lime px-[26px] py-3.5 text-[15px] font-semibold text-lime-deep no-underline transition-[filter] hover:brightness-[1.04]"
            ><Cloud class="h-[18px] w-[18px]" stroke-width={1.8} /> Get started →</a
          >
          <a
            href={GITHUB}
            data-hover
            data-hover-lift="-3"
            class="inline-flex items-center gap-2 rounded-xl border border-line-strong bg-surface px-[26px] py-3.5 text-[15px] font-semibold text-ink-700 no-underline transition-colors hover:bg-surface-sunken"
            ><BrandIcon name="docker" class="h-[18px] w-[18px]" /> Deploy with Docker →</a
          >
        </div>
        <div
          class="mt-[22px] break-all font-mono text-[11px] text-ink-400 sm:text-[12.5px]"
        >
          docker pull ghcr.io/coollabsio/shoutrrr:latest
        </div>
        <div
          class="mt-4 inline-flex items-center gap-1.5 text-[12.5px] font-medium text-ink-400"
        >
          <Server class="h-4 w-4 text-lime-text" stroke-width={1.8} /> …or
          self-host free with the command above
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section id="faq" class="mx-auto max-w-3xl px-6 pb-28">
    <div data-reveal class="mb-12 text-center">
      <div
        class="mb-3.5 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
      >
        Questions
      </div>
      <h2
        class="font-display text-[clamp(28px,4vw,40px)] font-medium leading-[1.1]"
      >
        Answers in plain language
      </h2>
    </div>
    <div data-reveal class="divide-y divide-line border-y border-line">
      {
        faqs.map((item) => (
          <details class="faq group">
            <summary
              class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-[15px] font-semibold text-ink-800 [&::-webkit-details-marker]:hidden"
            >
              <span>{item.q}</span>
              <svg
                class="h-5 w-5 flex-shrink-0 text-ink-300 transition-transform duration-200 group-open:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <p class="-mt-1 pb-5 pr-9 text-sm leading-[1.6] text-ink-500">
              {item.a}
            </p>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
