---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- Hero Section -->
  <section class="pt-12 md:pt-24 pb-10 text-center">
    <h1 class="text-3xl md:text-6xl font-bold tracking-tight">
      Self-hosted social scheduling<span class="text-[#FCD34D]">.</span>
    </h1>
    <p
      class="mt-6 text-neutral-400 max-w-4xl mx-auto text-base md:text-lg leading-relaxed"
    >
      An open-source alternative to Buffer, Typefully, and Hootsuite.
      Write once and schedule posts to X, Bluesky, and LinkedIn. More platforms coming soon.
    </p>

    <!-- Hosted Coming Soon -->
    <div
      class="mt-6 inline-flex items-center gap-2 bg-coolgray-300/60 text-sm px-4 py-2 rounded"
    >
      <svg
        class="w-4 h-4 text-[#FCD34D]"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"
        ></path>
      </svg>
      <span class="text-neutral-400">Hosted version coming soon</span>
    </div>

    <!-- CTA Buttons -->
    <!-- <div class="mt-10 flex flex-col sm:flex-row justify-center items-center gap-4">
      <a
        href="#features"
        class="p-3 px-8 rounded text-white border border-coollabs hover:bg-coollabs bg-coollabs/30 font-semibold text-base flex items-center gap-2 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        Get Started
      </a>
    </div> -->

    <!-- GitHub Link -->
    <div class="mt-8 max-w-xl mx-auto">
      <a
        href="https://github.com/coollabsio/shoutrrr"
        class="font-mono bg-coolgray-300 px-4 py-3 rounded text-xs md:text-sm text-left flex items-center justify-between"
        aria-label="Open Shoutrrr on GitHub"
      >
        <div>
          <span class="select-none text-neutral-400">$ </span>
          <span>github.com/coollabsio/shoutrrr</span>
        </div>
        <span class="text-neutral-400 ml-4 flex-shrink-0">
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- Most Useful Features Intro -->
  <section id="features" class="mt-16 px-4 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#FCD34D]">
      Most useful features
    </p>
    <h2 class="mt-4 text-2xl md:text-4xl font-bold tracking-tight">
      The parts of Shoutrrr you'll use every day<span class="text-[#FCD34D]">.</span>
    </h2>
    <p class="mt-4 max-w-3xl mx-auto text-neutral-400 text-base md:text-lg leading-relaxed">
      Composer, scheduling, workspaces, connected accounts, and analytics are
      the core workflows that make Shoutrrr more than a posting form.
    </p>
  </section>

  <!-- Publish Everywhere Feature -->
  <section class="mt-10 pb-10 px-4">
    <div class="rounded-3xl border border-[#FCD34D]/20 bg-gradient-to-br from-coolgray-300 via-coolgray-200 to-[#101010] p-6 md:p-10 overflow-hidden relative">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#FCD34D]/60 to-transparent"></div>
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#FCD34D]">
            Publish everywhere
          </p>
          <h3 class="mt-4 text-2xl md:text-5xl font-bold tracking-tight">
            Compose once. Schedule it everywhere<span class="text-[#FCD34D]">.</span>
          </h3>
          <p class="mt-6 text-neutral-300 text-base md:text-lg leading-relaxed">
            Write a post once, customize it per network when needed, and send it
            to X, Bluesky, and LinkedIn from one self-hosted workspace. More
            platforms are coming soon.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a
              href="https://github.com/coollabsio/shoutrrr"
              class="inline-flex items-center justify-center gap-2 rounded bg-[#FCD34D] px-5 py-3 text-sm font-semibold text-[#101010] hover:bg-yellow-300 transition-colors"
            >
              View on GitHub
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-coolgray-500 bg-[#101010]/70 p-5 md:p-6 shadow-2xl shadow-black/30">
          <div class="flex items-center gap-3 border-b border-coolgray-400 pb-4">
            <div class="flex -space-x-2">
              <span class="grid h-9 w-9 place-items-center rounded-full border border-coolgray-500 bg-coolgray-300 text-xs font-semibold">X</span>
              <span class="grid h-9 w-9 place-items-center rounded-full border border-coolgray-500 bg-coolgray-300 text-xs font-semibold">BS</span>
              <span class="grid h-9 w-9 place-items-center rounded-full border border-coolgray-500 bg-coolgray-300 text-xs font-semibold">in</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Multi-platform composer</p>
              <p class="text-xs text-neutral-400">One draft, multiple social accounts</p>
            </div>
          </div>

          <ul class="mt-5 space-y-4 text-sm text-neutral-300">
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-[#FCD34D] text-[#FCD34D] text-xs">✓</span>
              <span>Live character counts and per-platform copy overrides.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-[#FCD34D] text-[#FCD34D] text-xs">✓</span>
              <span>Media, alt text, and thread support where the platform allows it.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-[#FCD34D] text-[#FCD34D] text-xs">✓</span>
              <span>Reusable account sets for publishing to the right channels faster.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Daily Workflows Section -->
  <section class="mt-6 pb-10 px-4">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#FCD34D]">
        Daily workflows
      </p>
      <h2 class="mt-4 text-2xl md:text-4xl font-bold tracking-tight">
        Plan, collaborate, and learn what worked<span class="text-[#FCD34D]">.</span>
      </h2>
      <p class="mt-4 text-neutral-400 text-base md:text-lg leading-relaxed">
        Keep your content calendar organized, separate brands or clients, and
        track performance without handing your workflow to a hosted platform.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 lg:grid-cols-2 gap-6">
      <article class="rounded-3xl border border-coolgray-400 bg-coolgray-300/80 p-6 md:p-8">
        <div class="flex items-start gap-3">
          <div class="mt-1 grid h-12 w-12 flex-shrink-0 place-items-center rounded-2xl bg-[#FCD34D]/10 text-[#FCD34D]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3.75 8.25h16.5M4.5 6.75h15A1.5 1.5 0 0121 8.25v10.5A1.5 1.5 0 0119.5 20.25h-15A1.5 1.5 0 013 18.75V8.25A1.5 1.5 0 014.5 6.75z" /></svg>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#FCD34D]">Queue and calendar</p>
            <h3 class="text-2xl font-bold text-white">Plan posts before the week gets busy.</h3>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-neutral-300">
          Set recurring posting slots in your workspace timezone, queue drafts,
          review the month calendar, and publish instantly when needed.
        </p>
      </article>

      <article class="rounded-3xl border border-coolgray-400 bg-coolgray-300/80 p-6 md:p-8">
        <div class="flex items-start gap-3">
          <div class="mt-1 grid h-12 w-12 flex-shrink-0 place-items-center rounded-2xl bg-[#FCD34D]/10 text-[#FCD34D]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75A2.25 2.25 0 016 4.5h4.5l2.25 2.25H18a2.25 2.25 0 012.25 2.25v8.25A2.25 2.25 0 0118 19.5H6a2.25 2.25 0 01-2.25-2.25V6.75z" /></svg>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#FCD34D]">Workspaces and teams</p>
            <h3 class="text-2xl font-bold text-white">Keep brands, clients, and people separated.</h3>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-neutral-300">
          Invite collaborators, assign roles, transfer ownership, and keep every
          post, account, and metric scoped to the right workspace.
        </p>
      </article>

      <article class="rounded-3xl border border-coolgray-400 bg-coolgray-300/80 p-6 md:p-8">
        <div class="flex items-start gap-3">
          <div class="mt-1 grid h-12 w-12 flex-shrink-0 place-items-center rounded-2xl bg-[#FCD34D]/10 text-[#FCD34D]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#FCD34D]">Analytics</p>
            <h3 class="text-2xl font-bold text-white">See how accounts and posts perform.</h3>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-neutral-300">
          Track follower and post-count trends per account, plus per-post
          engagement such as likes, reposts, replies, and impressions.
        </p>
      </article>

      <article class="rounded-3xl border border-coolgray-400 bg-coolgray-300/80 p-6 md:p-8">
        <div class="flex items-start gap-3">
          <div class="mt-1 grid h-12 w-12 flex-shrink-0 place-items-center rounded-2xl bg-[#FCD34D]/10 text-[#FCD34D]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#FCD34D]">Self-hosted</p>
            <h3 class="text-2xl font-bold text-white">Free & Open-source forever.</h3>
          </div>
        </div>
        <p class="mt-5 text-sm leading-6 text-neutral-300">
          Run the full product on your own infrastructure. No paid tiers, no
          feature gates, and no hosted-service limits in the open-source app.
        </p>
      </article>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="mt-16 pb-10">
    <h2 class="text-2xl md:text-4xl font-bold text-center">
      Frequently asked questions<span class="text-[#FCD34D]">.</span>
    </h2>
    <p class="mt-4 text-neutral-400 text-center max-w-2xl mx-auto">
      Quick answers in plain language.
    </p>

    <div
      class="mt-12 max-w-3xl mx-auto divide-y divide-coolgray-300 border-y border-coolgray-300"
    >
      <!-- FAQ 1 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>What platforms does shoutrrr support?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          Shoutrrr works with X, Bluesky, and LinkedIn today. You can write
          once, adjust each post when needed, and schedule everything from one place.
        </p>
      </div>

      <!-- FAQ 2 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>Is shoutrrr really free?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          Yes. The <a
            href="https://github.com/coollabsio/shoutrrr"
            class="text-[#FCD34D] underline decoration-[#FCD34D]/40 underline-offset-4 hover:text-[#FDE68A]"
            target="_blank"
            rel="noopener noreferrer">open-source app</a
          > is free to use, and you can run it on your own server. There are no
          paid seats or locked features in the self-hosted version.
        </p>
      </div>

      <!-- FAQ 3 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>How do I install shoutrrr?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          The easiest path is to run the ready-made Docker setup from the
          <a
            href="https://github.com/coollabsio/shoutrrr"
            class="text-[#FCD34D] underline decoration-[#FCD34D]/40 underline-offset-4 hover:text-[#FDE68A]"
            target="_blank"
            rel="noopener noreferrer">GitHub repository</a
          >. It gives you the app and everything it needs without building it
          by hand.
        </p>
      </div>

      <!-- FAQ 4 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>Can I use it with my team?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          Yes. You can invite teammates, organize work into separate spaces,
          and keep different brands, clients, or projects apart.
        </p>
      </div>

      <!-- FAQ 5 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>Is my data safe?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          Shoutrrr is self-hosted, so your posts, accounts, and analytics stay
          on infrastructure you control. Account connection details are protected
          by the app.
        </p>
      </div>

      <!-- FAQ 6 -->
      <div class="faq-item py-4">
        <button
          class="faq-button w-full text-left text-sm font-medium flex justify-between items-center text-white"
          aria-expanded="false"
        >
          <span>How do I contribute?</span>
          <svg
            class="w-6 h-6 transition-transform duration-200 flex-shrink-0"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <p class="faq-answer hidden mt-2 text-sm text-neutral-300 text-left">
          Visit the <a
            href="https://github.com/coollabsio/shoutrrr"
            class="text-[#FCD34D] underline decoration-[#FCD34D]/40 underline-offset-4 hover:text-[#FDE68A]"
            target="_blank"
            rel="noopener noreferrer">GitHub repository</a
          > to report bugs, suggest improvements, update docs, or open a pull
          request. Every useful contribution helps.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // FAQ accordion
  document.querySelectorAll(".faq-button").forEach((button) => {
    button.addEventListener("click", () => {
      const answer = button.nextElementSibling as HTMLElement;
      const isOpen = button.getAttribute("aria-expanded") === "true";

      // Close all
      document.querySelectorAll(".faq-button").forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
        const chevron = btn.querySelector("svg");
        if (chevron) chevron.style.transform = "";
        const ans = btn.nextElementSibling as HTMLElement;
        if (ans) ans.classList.add("hidden");
      });

      // Toggle current
      if (!isOpen) {
        button.setAttribute("aria-expanded", "true");
        const chevron = button.querySelector("svg");
        if (chevron) chevron.style.transform = "rotate(180deg)";
        if (answer) answer.classList.remove("hidden");
      }
    });
  });

</script>
