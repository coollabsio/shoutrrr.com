---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import Breadcrumbs from '../../components/docs/Breadcrumbs.astro';
import PageNav from '../../components/docs/PageNav.astro';
import LastModified from '../../components/docs/LastModified.astro';
import Tabs from '../../components/docs/mdx/Tabs.astro';
import Tab from '../../components/docs/mdx/Tab.astro';
import Steps from '../../components/docs/mdx/Steps.astro';
import Step from '../../components/docs/mdx/Step.astro';
import Accordions from '../../components/docs/mdx/Accordions.astro';
import Accordion from '../../components/docs/mdx/Accordion.astro';
import TypeTable from '../../components/docs/mdx/TypeTable.astro';
import Banner from '../../components/docs/mdx/Banner.astro';
import ApiReference from '../../components/docs/api/ApiReference.astro';
import { getApiTags, operationAnchor } from '../../lib/api/openapi.js';
import {
  getDocsSource,
  entryToSlug,
  getNeighbours,
  getBreadcrumbs,
  getLastModified,
  DOCS_BASE_URL,
} from '../../lib/docs/source';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => ({
    params: { slug: entryToSlug(entry.id) },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'docs'> };
const { entry } = Astro.props;

const { Content, headings } = await render(entry);
const source = await getDocsSource();
const tree = source.getPageTree();

// Current page metadata from the fumadocs source (for the active nav state).
const page = source.getPage(entry.id === 'index' ? [] : entry.id.split('/'));
const currentUrl = page?.url ?? DOCS_BASE_URL;

const neighbours = getNeighbours(tree, currentUrl);
const crumbs = getBreadcrumbs(tree, currentUrl);
const lastModified = getLastModified(entry.id);

// API tag pages render the OpenAPI reference and contribute their operation
// headings to the TOC (component-rendered headings aren't in `headings`).
const apiTag = entry.data.apiTag;
const apiGroup = apiTag ? getApiTags().find((t: any) => t.tag === apiTag) : null;
const apiHeadings = apiGroup
  ? apiGroup.operations.map((op: any) => ({
      depth: 3,
      slug: operationAnchor(op),
      text: `${op.method} ${op.path}`,
    }))
  : [];
const allHeadings = [...headings, ...apiHeadings];

// Custom components authors can use in MDX without importing them per file.
const mdxComponents = {
  Tabs,
  Tab,
  Steps,
  Step,
  Accordions,
  Accordion,
  TypeTable,
  Banner,
};

// Structured data for search engines: the article plus its breadcrumb trail.
const pageUrl = new URL(currentUrl, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: entry.data.title,
      description: entry.data.description,
      url: pageUrl,
      ...(lastModified ? { dateModified: lastModified } : {}),
      inLanguage: 'en',
      isPartOf: { '@type': 'WebSite', name: 'Shoutrrr', url: Astro.site?.href },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: crumbs.map((crumb, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: crumb.name,
        ...(crumb.url ? { item: new URL(crumb.url, Astro.site).href } : {}),
      })),
    },
  ],
};
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  tree={tree}
  headings={allHeadings}
  currentUrl={currentUrl}
  jsonLd={jsonLd}
>
  <Breadcrumbs crumbs={crumbs} />
  <h1 class="mb-2 font-display text-[2.25rem] leading-tight tracking-tight text-ink">
    {entry.data.title}
  </h1>
  {
    entry.data.description && (
      <p class="mb-8 text-lg text-ink-500">{entry.data.description}</p>
    )
  }
  <div class="docs-prose">
    <Content components={mdxComponents} />
    {apiTag && <ApiReference tag={apiTag} />}
  </div>
  {lastModified && <LastModified date={lastModified} />}
  <PageNav neighbours={neighbours} />
</DocsLayout>
