---
import Layout from '../layouts/Layout.astro';
import BrandIcon from '../components/marketing/BrandIcon.astro';
import CircleCheck from 'lucide-astro/CircleCheck';

const commitments = [
  {
    title: 'Free and open source.',
    body: 'Every project we build is 100% open source. You can view the code, modify it, learn from it, and use it however you want.',
  },
  {
    title: 'No features behind paywalls.',
    body: 'Every feature we develop goes into the open-source version. There\'s no "enterprise edition" with the good stuff locked away. What you see is what you get — everything.',
  },
  {
    title: 'Apache 2.0 license.',
    body: 'The Apache 2.0 license gives you the freedom to use our software for any purpose. We just kindly ask that you don\'t commercially redistribute our work as your own product.',
  },
  {
    title: 'Forever free.',
    body: 'This isn\'t a temporary strategy or a growth hack. This is how we believe software should be made. These principles will never change.',
  },
];

const stats = [
  { id: 'hosted-mrr', value: '15,200', label: 'MRR', href: 'https://coolify.io/cloud' },
  { id: 'github-sponsors', value: '4,500', label: 'GitHub Sponsors / month', href: 'https://github.com/sponsors/coollabsio' },
  { id: 'open-collective', value: '1,200', label: 'Open Collective / month', href: 'https://opencollective.com/coollabsio' },
];
---

<Layout
  title="Our Philosophy | Shoutrrr"
  description="Our approach to open-source software: free, accessible, and community-supported. Learn about our philosophy and how we sustain development."
>
  <article class="mx-auto max-w-3xl px-6 pb-28 pt-16 md:pt-24">
    <!-- Intro -->
    <header data-reveal class="max-w-2xl">
      <div
        class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-lime-text"
      >
        Our philosophy
      </div>
      <h1
        class="font-display text-[clamp(36px,5vw,56px)] font-medium leading-[1.04]"
      >
        Software should be free and accessible to everyone
      </h1>
      <p class="mt-6 text-[17px] leading-[1.7] text-ink-500">
        We believe great software should be available to everyone, regardless of
        budget. That's why all of our projects are completely free and open
        source, with no features locked behind paywalls.
      </p>
      <p class="mt-4 text-[17px] leading-[1.7] text-ink-500">
        This isn't just a business decision — it's a core belief. We've seen too
        many promising open-source projects slowly close their doors, adding
        "enterprise" features and artificial limitations. We chose a different
        path.
      </p>
    </header>

    <!-- Commitments -->
    <section data-reveal class="mt-20">
      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-medium">
        What this means
      </h2>
      <p class="mt-2 text-ink-400">Our commitments to the community.</p>
      <ul class="mt-8 space-y-6">
        {
          commitments.map((c) => (
            <li class="flex gap-3.5 rounded-2xl border border-line-soft p-5">
              <CircleCheck
                class="mt-0.5 h-5 w-5 flex-none text-lime-text"
                stroke-width={1.8}
              />
              <span class="text-[15px] leading-[1.6] text-ink-500">
                <strong class="font-semibold text-ink">{c.title}</strong>{' '}
                {c.body}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Sustaining development -->
    <section data-reveal class="mt-20">
      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-medium">
        How we sustain development
      </h2>
      <p class="mt-2 text-ink-400">Because we still need to pay the bills.</p>
      <div class="mt-6 space-y-4 text-[16px] leading-[1.7] text-ink-500">
        <p>
          Making software free doesn't mean development is free. We sustain our
          work through two main channels:
        </p>
        <p>
          <strong class="text-ink">Community donations.</strong> If you find our
          projects valuable, you can support us through GitHub Sponsors or Open
          Collective. Every contribution helps us dedicate more time to
          development and support.
        </p>
        <p>
          <strong class="text-ink">Hosted services.</strong> A managed cloud
          version is coming soon for those who prefer not to self-host. You'll
          get the same features, we handle the infrastructure, and the revenue
          helps fund continued development.
        </p>
        <p>
          This model lets us focus on building great software for real users —
          not on pleasing investors or hitting arbitrary growth metrics.
        </p>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="https://github.com/sponsors/coollabsio"
          target="_blank"
          rel="noopener"
          data-hover
          class="flex w-full items-center justify-center gap-3 rounded-xl border border-line-strong bg-surface px-4 py-3 no-underline transition-colors hover:bg-surface-sunken sm:w-64"
        >
          <BrandIcon name="github" class="h-7 w-7 text-ink" />
          <span class="flex flex-col text-left">
            <span class="text-sm font-bold text-ink">GitHub Sponsors</span>
            <span class="text-xs text-ink-300">Support us</span>
          </span>
        </a>
        <a
          href="https://opencollective.com/coollabsio"
          target="_blank"
          rel="noopener"
          data-hover
          class="flex w-full items-center justify-center gap-3 rounded-xl border border-line-strong bg-surface px-4 py-3 no-underline transition-colors hover:bg-surface-sunken sm:w-64"
        >
          <svg class="h-7 w-7 text-net-bs" viewBox="0 0 24 24" fill="none">
            <path
              d="M16.6818 15.7529L18.8116 17.8827C20.1752 16.3052 21 14.249 21 12.0001C21 9.78747 20.2016 7.76133 18.8771 6.19409L16.7444 8.32671C17.5315 9.34177 18 10.6162 18 12.0001C18 13.4203 17.5066 14.7253 16.6818 15.7529Z"
              fill="currentColor"
              fill-opacity="0.5"></path>
            <path
              d="M15.6734 16.7445C14.6583 17.5315 13.3839 18 12 18C8.68629 18 6 15.3137 6 12C6 8.68629 8.68629 6 12 6C13.4202 6 14.7252 6.49344 15.7528 7.31823L17.8826 5.18843C16.3051 3.82482 14.2489 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21C14.2126 21 16.2387 20.2016 17.806 18.8771L15.6734 16.7445Z"
              fill="currentColor"></path>
          </svg>
          <span class="flex flex-col text-left">
            <span class="text-sm font-bold text-ink">Open Collective</span>
            <span class="text-xs text-ink-300">Support us</span>
          </span>
        </a>
      </div>
    </section>

    <!-- Numbers -->
    <section data-reveal class="mt-20">
      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-medium">
        Where we are today
      </h2>
      <p class="mt-2 text-ink-400">Transparency in numbers.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {
          stats.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              data-hover
              class="rounded-2xl border border-line-soft bg-surface-sunken p-6 no-underline transition-colors hover:border-line-strong"
            >
              <div class="font-display text-[clamp(28px,4vw,36px)] font-medium text-ink">
                $<span id={s.id}>{s.value}</span>+
              </div>
              <div class="mt-1 text-sm text-ink-400">{s.label}</div>
            </a>
          ))
        }
      </div>
      <p class="mt-6 text-[16px] leading-[1.7] text-ink-500">
        This revenue allows us to work on these projects full-time, hire help,
        and keep improving the software for everyone.
      </p>
    </section>

    <!-- Closing -->
    <section data-reveal class="mt-16 border-t border-line pt-10">
      <p class="text-[16px] leading-[1.7] text-ink-500">
        This philosophy guides everything we do at{' '}
        <a href="https://coollabs.io" class="font-semibold text-ink underline decoration-lime-ring underline-offset-4 hover:text-lime-deep">coolLabs</a>.
        Whether it's the scheduler itself or any other tool we build, the
        principles remain the same: free, open, and built for the community.
      </p>
      <p class="mt-4 text-[16px] leading-[1.7] text-ink-500">
        Thank you to everyone who supports this vision — through donations, by
        using our hosted services, or simply by using and sharing our software.
        You make this possible.
      </p>
    </section>
  </article>

  <script>
    fetch('https://cdn.coollabs.io/business.json')
      .then((res) => res.json())
      .then((data) => {
        const set = (id: string, v: unknown) => {
          const el = document.getElementById(id);
          if (el && typeof v === 'number') el.textContent = v.toLocaleString();
        };
        set('hosted-mrr', data.mrr);
        set('github-sponsors', data['github-sponsors']);
        set('open-collective', data['open-collective-sponsors']);
      })
      .catch(() => {});
  </script>
</Layout>
