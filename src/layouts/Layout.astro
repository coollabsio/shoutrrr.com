---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

// Self-hosted brand faces — same families as the Shoutrrr app.
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Shoutrrr — Open-source social scheduling',
  description = 'The open-source alternative to Buffer, Typefully & Hootsuite. Draft once, post everywhere — schedule to X, Bluesky, and LinkedIn. Self-host it free, or use the managed Cloud (coming soon).',
} = Astro.props;

// Absolute, self-referencing canonical (Astro.site set in astro.config.mjs).
const canonical = new URL(Astro.url.pathname, Astro.site);
const iconVersion = '2026-06-megaphone';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <!-- Add the `js` class before first paint so reveal targets only hide when
         motion can actually run them. -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Shoutrrr" />
    <meta property="og:image" content="https://shoutrrr.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://shoutrrr.com/og-image.png" />

    <!-- App icons -->
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${iconVersion}`} />
    <link rel="icon" href={`/favicon.ico?v=${iconVersion}`} sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16x16.png?v=${iconVersion}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32x32.png?v=${iconVersion}`} />
    <link rel="icon" type="image/png" sizes="48x48" href={`/favicon-48x48.png?v=${iconVersion}`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${iconVersion}`} />
    <link rel="manifest" href={`/site.webmanifest?v=${iconVersion}`} />
    <meta name="theme-color" content="#ffffff" />

    <title>{title}</title>
  </head>
  <body class="bg-surface font-sans text-ink antialiased">
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
    <script
      defer
      data-domain="shoutrrr.com"
      src="https://analytics.coollabs.io/js/script.tagged-events.js"></script>
    <script>
      import '../scripts/motion-init.ts';
    </script>
  </body>
</html>
