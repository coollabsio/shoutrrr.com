const color = brand ? icon.color : 'currentColor';
---

<svg
  viewBox={icon.viewBox}
  class={className}
  style={`color:${color}`}
  role={title ? 'img' : 'presentation'}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
  set:html={icon.body}
></svg>
