---
interface Props {
  title: string;
  open?: boolean;
}
const { title, open } = Astro.props;
---

<details class="docs-accordion" open={open}>
  <summary class="docs-accordion-summary">
    <span>{title}</span>
    <svg
      class="docs-accordion-chevron"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="docs-accordion-body"><slot /></div>
</details>
