---
import type { PageNeighbours } from '../../lib/docs/source';

interface Props {
  neighbours: PageNeighbours;
}

const { neighbours } = Astro.props;
const { previous, next } = neighbours;
---

{
  (previous || next) && (
    <nav
      aria-label="Page navigation"
      class="mt-14 grid gap-4 border-t border-line pt-8 sm:grid-cols-2"
    >
      {previous ? (
        <a
          href={previous.url}
          class="group flex flex-col gap-1 rounded-xl border border-line bg-surface-sunken px-4 py-3 no-underline transition-colors hover:border-line-strong hover:bg-surface"
        >
          <span class="flex items-center gap-1 text-xs font-medium uppercase tracking-wide text-ink-300">
            <svg
              class="size-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
            Previous
          </span>
          <span class="font-medium text-ink transition-colors group-hover:text-lime-text">
            {previous.name}
          </span>
        </a>
      ) : (
        <span />
      )}
      {next && (
        <a
          href={next.url}
          class="group flex flex-col gap-1 rounded-xl border border-line bg-surface-sunken px-4 py-3 text-right no-underline transition-colors hover:border-line-strong hover:bg-surface sm:col-start-2"
        >
          <span class="flex items-center justify-end gap-1 text-xs font-medium uppercase tracking-wide text-ink-300">
            Next
            <svg
              class="size-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </span>
          <span class="font-medium text-ink transition-colors group-hover:text-lime-text">
            {next.name}
          </span>
        </a>
      )}
    </nav>
  )
}
