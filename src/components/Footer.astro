---
import BrandIcon from './marketing/BrandIcon.astro';
const GITHUB = 'https://github.com/coollabsio/shoutrrr';
const socials = [
  { name: 'github', href: GITHUB, label: 'GitHub' },
  { name: 'x', href: 'https://x.com/heyandras', label: 'X' },
  { name: 'bluesky', href: 'https://bsky.app/profile/heyandras.dev', label: 'Bluesky' },
] as const;
const cols = [
  {
    title: 'Product',
    links: [
      { href: '/#features', label: 'Features' },
      { href: '/#showcase', label: 'Composer' },
      { href: '/#showcase', label: 'Calendar' },
      { href: '/#showcase', label: 'Analytics' },
    ],
  },
  {
    title: 'Project',
    links: [
      { href: GITHUB, label: 'GitHub' },
      { href: `${GITHUB}#readme`, label: 'Documentation' },
      { href: '/philosophy', label: 'Philosophy' },
      { href: '/sponsorships', label: 'Sponsor us' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: '/#get', label: 'Self-hosting guide' },
      { href: '/#security', label: 'Security' },
      { href: 'https://coollabs.io/discord', label: 'Community' },
      { href: `${GITHUB}/blob/main/LICENSE`, label: 'License (Apache 2.0)' },
    ],
  },
];
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div
    class="mx-auto grid max-w-site gap-8 px-6 py-14 sm:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr]"
  >
    <div>
      <div class="mb-3.5 flex items-center gap-2.5">
        <img src="/shoutrrr.png" alt="" width="28" height="28" class="h-7 w-7" />
        <span class="text-[17px] font-bold">Shoutrrr</span>
      </div>
      <p class="m-0 max-w-[240px] text-[13.5px] leading-[1.6] text-ink-400">
        The open-source social scheduler. Draft once, post everywhere, keep your
        data. Self-host it, or use the managed Cloud — coming soon.
      </p>
      <div class="mt-5 flex items-center gap-2">
        {
          socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="grid h-9 w-9 place-items-center rounded-lg border border-line text-ink-400 no-underline transition-colors hover:border-line-strong hover:text-ink"
            >
              <BrandIcon name={s.name} class="h-[18px] w-[18px]" />
            </a>
          ))
        }
      </div>
    </div>

    {
      cols.map((col) => (
        <div>
          <div class="mb-3.5 text-xs font-bold uppercase tracking-[0.06em] text-ink-500">
            {col.title}
          </div>
          <div class="flex flex-col gap-2.5 text-[13.5px] text-ink-400">
            {col.links.map((l) => (
              <a
                href={l.href}
                class="text-inherit no-underline transition-colors hover:text-ink"
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="border-t border-line">
    <div
      class="mx-auto flex max-w-site flex-wrap justify-between gap-2 px-6 py-[18px] text-[12.5px] text-ink-300"
    >
      <span>© {year} Shoutrrr · Apache 2.0 licensed</span>
      <span>Open source · Self-host or Cloud</span>
    </div>
  </div>
</footer>
